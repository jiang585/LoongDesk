{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "pet"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "sql:default",
    "sql:allow-execute",
    "opener:default",
    "stronghold:default",
    "global-shortcut:default",
    "updater:default",
    "process:default"
  ]
}
